# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sales_crm

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_12345!
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_54321!
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Seeding & Initial Credentials
SUPER_ADMIN_EMAIL=superadmin@salescrm.com
SUPER_ADMIN_PASSWORD=Admin@123456
